# ============================================================
# Polymarket 自动套利系统 - 环境变量模板
# ============================================================
# ⚠️  复制此文件为 .env 并填入真实值
# ⚠️  .env 已在 .gitignore 中，严禁提交至 GitHub
# ============================================================

# ---- L1 钱包 (EIP-712 签名用) ----
# 必须与 Polymarket 网站 API 页面显示的「地址」一致
PRIVATE_KEY=0x_your_l1_private_key_here
WALLET_ADDRESS=0x_your_wallet_address_here

# ---- V2 存款钱包 (Deposit Wallet / Proxy) ----
# Polymarket 充值后分配的链上代理合约地址 (23 bytes code)
DEPOSIT_WALLET=0x_your_deposit_wallet_here
# V2 签名类型: 2=POLY_NETWORK (推荐), 3=POLY_1271
SIGNATURE_TYPE=2

# ---- L2 API 凭证 (Polymarket CLOB) ----
# 从 polymarket.com 设置页导出, 三项必须配套使用
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here
API_PASSPHRASE=your_api_passphrase_here

# ---- Polygon RPC 节点 (Alchemy / QuickNode) ----
RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_project_id

# ---- 交易参数 ----
# 单笔套利最大资金 (USD)
MAX_TRADE_SIZE=2.0
# 最小套利利润阈值 (USD)
MIN_PROFIT_THRESHOLD=0.0001
# 滑点容忍上限
MAX_SLIPPAGE_PCT=0.5

# ---- 市场过滤 ----
# 最低交易量 (USD) - Polymarket volume 单位可能是 cents
GAMMA_MIN_VOLUME=500
# 最低流动性 (USD)
GAMMA_MIN_LIQUIDITY=500

# ---- 风控参数 ----
# 连续失败熔断阈值
CONSECUTIVE_FAIL_LIMIT=3
# 熔断冷却时间 (秒)
CIRCUIT_BREAKER_COOLDOWN=900

# ---- Gamma API ----
GAMMA_API_URL=https://gamma-api.polymarket.com

# ---- CLOB API ----
CLOB_API_URL=https://clob.polymarket.com
CLOB_WS_MARKET_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
CLOB_WS_USER_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user

# ---- Telegram Bot (Phase 4) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Phase 4 Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
HEARTBEAT_INTERVAL_SECONDS=3600

# ---- Phase 3 Go/No-Go auto-notification ----
PHASE3_NOTIFY_ENABLED=true
PHASE3_MIN_UPTIME_HOURS=48
PHASE3_MIN_ATTEMPTS=100
PHASE3_MAX_LEG_RISK_RATE=0.05
PHASE3_MIN_SLIPPAGE_PASS_RATE=0.90
PHASE3_CHECK_INTERVAL_SECONDS=3600
PHASE3_GHOST_GRACE_SECONDS=1800
