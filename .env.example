# ============================================================
# Polymarket 自动套利系统 - 环境变量模板
# ============================================================
# ⚠️  复制此文件为 .env 并填入真实值
# ⚠️  .env 已在 .gitignore 中，严禁提交至 GitHub
# ============================================================

# ---- L1 钱包 (EIP-712 签名用) ----
PRIVATE_KEY=0x_your_l1_private_key_here

# ---- L2 API 凭证 (Polymarket CLOB) ----
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here
API_PASSPHRASE=your_api_passphrase_here

# ---- Polygon RPC 节点 (Alchemy / QuickNode) ----
RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_project_id

# ---- 交易参数 ----
# 单笔套利最大资金 (USD)
MAX_TRADE_SIZE=2.0
# 最小套利利润阈值 (USD)
MIN_PROFIT_THRESHOLD=0.005
# 滑点容忍上限
MAX_SLIPPAGE_PCT=0.5

# ---- 风控参数 ----
# 连续失败熔断阈值
CONSECUTIVE_FAIL_LIMIT=3
# 熔断冷却时间 (秒)
CIRCUIT_BREAKER_COOLDOWN=900

# ---- Gamma API ----
GAMMA_API_URL=https://gamma-api.polymarket.com

# ---- CLOB API ----
CLOB_API_URL=https://clob.polymarket.com
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws

# ---- Telegram Bot (Phase 4) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=